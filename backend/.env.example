PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
FRONTEND_URL=http://localhost:5177
# Optional: comma-separated extra frontend origins, useful for Vercel aliases/previews.
# FRONTEND_URLS=https://your-frontend-domain.vercel.app,https://your-preview-domain.vercel.app
NODE_ENV=development
# Supabase is not required for the current FOOTY HUB release.
# Do not add Supabase env vars to Render unless a future optional feature uses them.
# Optional: set only if Node.js cannot resolve MongoDB Atlas SRV records on your network.
# DNS_SERVERS=1.1.1.1,8.8.8.8
