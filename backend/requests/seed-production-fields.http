@baseUrl = https://footy-hub-backend.onrender.com
@adminEmail = fong@test.com 
@adminPassword = 123456

### Login as admin first
# @name adminLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

### Check current production fields
GET {{baseUrl}}/api/fields

### Seed Field 1: Neon Turf Arena
POST {{baseUrl}}/api/fields
Content-Type: application/json
Authorization: Bearer {{adminLogin.response.body.token}}

{
  "name": "Neon Turf Arena",
  "location": "Zone A",
  "description": "Modern football field for casual matches, team training, and community games.",
  "pricePerHour": 1200,
  "fieldType": "7-a-side",
  "images": ["https://images.unsplash.com/photo-1575361204480-aadea25e6e68"],
  "openTime": "10:00",
  "closeTime": "22:00",
  "facilities": ["parking", "shower", "water", "locker"],
  "isActive": true
}

